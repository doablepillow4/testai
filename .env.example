# ============================================================
# Hivemind Predictor — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ------------------------------------------------------------
# Database (required)
# ------------------------------------------------------------
# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hivemind

# ------------------------------------------------------------
# Server (optional)
# ------------------------------------------------------------
# Port the API server listens on. Defaults to 8080.
# PORT=8080

# Node environment. Use "development" locally, "production" in deployments.
# NODE_ENV=development
