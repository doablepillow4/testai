{
  "name": "testai",
  "private": true,
  "scripts": {
    "dev:full": "pnpm run db:up && pnpm run db:push && concurrently \"pnpm run backend:dev\" \"pnpm run frontend:dev\"",
    "db:up": "pnpm --filter @workspace/db run up",
    "db:push": "pnpm --filter @workspace/db run push",
    "backend:dev": "PORT=8080 pnpm --filter @workspace/api-server run dev",
    "frontend:dev": "PORT=5173 pnpm --filter @workspace/hivemind run dev -- --host 0.0.0.0",
    "dev:all": "pnpm run dev:full"
  }
}