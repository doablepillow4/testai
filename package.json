{
  "name": "testai",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm run dev:codespaces",
    "dev:all": "pnpm run dev:codespaces",
    "dev:codespaces": "concurrently \"pnpm run api:dev\" \"pnpm run frontend:dev\" --names API,FRONTEND",
    "api:dev": "PORT=8080 pnpm --filter @workspace/api-server run dev",
    "frontend:dev": "PORT=5173 pnpm --filter @workspace/hivemind run dev",
    "db:push": "pnpm --filter @workspace/db run push"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "concurrently": "^8.2.2"
  }
}
